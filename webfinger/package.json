{
  "name": "webfinger",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --minify --platform=node --format=esm --outfile=dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.x",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/standard-validator": "^0.2.2",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "hono-rate-limiter": "^0.5.3",
    "lru-cache": "^11.5.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
